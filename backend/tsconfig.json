{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "src/server.ts",
    "src/app.ts",
    "src/database/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
