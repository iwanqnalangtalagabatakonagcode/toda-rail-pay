{
  "name": "toda-rail-pay",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm --workspace frontend run dev\" \"npm --workspace backend run dev\"",
    "dev:frontend": "npm --workspace frontend run dev",
    "dev:backend": "npm --workspace backend run dev",
    "build": "npm --workspace frontend run build && npm --workspace backend run build",
    "build:contract": "cd contract && stellar contract build",
    "test": "cd contract && cargo test",
    "db:generate": "npm --workspace backend run db:generate",
    "db:seed": "npm --workspace backend run db:seed"
  },
  "workspaces": [
    "frontend",
    "backend"
  ],
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}